#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: run swiftformat on staged Swift files.
# Matches CI: `swiftformat --lint .` but only on staged files, and auto-fixes.

STAGED=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')

if [ -z "$STAGED" ]; then
  exit 0
fi

if ! command -v swiftformat &>/dev/null; then
  echo "warning: swiftformat not found, skipping format check"
  exit 0
fi

# Auto-fix the staged files in-place.
echo "$STAGED" | xargs swiftformat

# Re-stage any files that were reformatted.
echo "$STAGED" | xargs git add

exit 0
